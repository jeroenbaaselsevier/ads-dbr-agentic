# Databricks env (contains auth tokens — never commit)
.databricks/

# Synced remote library — generated by sync_library.sh, not source-controlled
rads_library/

# Synced metrics pipeline code — generated by sync_metrics_code.sh, not source-controlled
rads_metrics_code/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# OS
.DS_Store

# Local scratch and deliverables — not source-controlled
tmp/
output/

# Project-level generated artifacts (code + context are committed)
projects/*/output/
projects/*/tmp/
projects/*/cache-meta/

# Agent state (ephemeral working-tree state)
.agent-state/

# NOTE: agent-core/, .claude/, .agents/, .codex/, scripts/, platform/, tools/,
# agent-improvement/, and projects/ (code + context subdirs) are all
# intentionally tracked. Generated platform adapter files
# (.github/copilot-instructions.md, .github/agents/analyst.agent.md,
# CLAUDE.md, AGENTS.md, .claude/, .agents/, .codex/) are committed so they
# remain readable without running the build script.