# Copy this to .databricks/.databricks.env and fill in your values.
# This file is safe to commit; .databricks/ is gitignored.
#
# The Databricks VS Code extension fills this in automatically when you
# connect a cluster. You can also set these manually for CLI-only use.

DATABRICKS_AUTH_TYPE=metadata-service
DATABRICKS_BUNDLE_TARGET=dev
DATABRICKS_HOST=https://elsevier-dev.cloud.databricks.com/

# Cluster to attach for local interactive execution (Spark Connect).
# See README.md for available clusters.
DATABRICKS_CLUSTER_ID=0107-154653-j5wd510m

# Set by the VS Code Databricks extension — leave blank for CLI-only use.
DATABRICKS_METADATA_SERVICE_URL=

PYDEVD_WARN_SLOW_RESOLVE_TIMEOUT=10
PYTHONPATH=${PYTHONPATH}:${PWD}/rads_library
SPARK_CONNECT_PROGRESS_BAR_ENABLED=1
